{
  "name": "@hayrem_/mcp-minecraft-forge",
  "version": "0.1.1",
  "description": "MCP server for Forge Minecraft modding documentation with weekly auto-indexing",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-minecraft-forge": "dist/index.js"
  },
  "files": [
    "dist",
    "data/forge-docs.db",
    "scripts/postinstall.js"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "index-docs": "npx tsx scripts/index-docs.ts",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "minecraft",
    "forge",
    "modding",
    "mcp",
    "documentation",
    "ai",
    "claude",
    "cursor"
  ],
  "author": "Hayrem_",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hayremyt/mcp-minecraft-forge.git"
  },
  "bugs": {
    "url": "https://github.com/Hayremyt/mcp-minecraft-forge/issues"
  },
  "homepage": "https://github.com/Hayremyt/mcp-minecraft-forge",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hayrem_/mcp-minecraft-forge": "^0.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  }
}
